\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Generational Analysis (Claude)}{10}{subsection.4.3}\protected@file@percent }
\citation{kobak2024vocabulary}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Claude generational evolution: excess scores and lexical diversity. The left panel shows increasing mean excess scores across Claude generations (Haiku\nobreakspace  {}60.1 $\to $ Sonnet\nobreakspace  {}4\nobreakspace  {}74.4 $\to $ Opus\nobreakspace  {}4\nobreakspace  {}105.0), while the right panel shows monotonically declining Type-Token Ratio (0.52 $\to $ 0.32 $\to $ 0.29). This inverse relationship---greater capability accompanied by narrower vocabulary---suggests that RLHF and instruction tuning amplify lexical preferences at the expense of diversity.}}{11}{figure.5}\protected@file@percent }
\newlabel{fig:evolution}{{5}{11}{Claude generational evolution: excess scores and lexical diversity. The left panel shows increasing mean excess scores across Claude generations (Haiku~60.1 $\to $ Sonnet~4~74.4 $\to $ Opus~4~105.0), while the right panel shows monotonically declining Type-Token Ratio (0.52 $\to $ 0.32 $\to $ 0.29). This inverse relationship---greater capability accompanied by narrower vocabulary---suggests that RLHF and instruction tuning amplify lexical preferences at the expense of diversity}{figure.5}{}}
