\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Japanese Excess Words}{5}{subsection.4.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Top 20 Japanese excess words with statistical significance (Bonferroni-corrected).}}{5}{table.1}\protected@file@percent }
\newlabel{tab:top20}{{1}{5}{Top 20 Japanese excess words with statistical significance (Bonferroni-corrected)}{table.1}{}}
\@writefile{toc}{\contentsline {paragraph}{AI-Only Word Analysis.}{5}{section*.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Top 30 Japanese excess words ranked by excess score. The horizontal axis shows the excess score (ratio of AI--human frequency difference to human frequency), while bars represent individual words. Words at the top (Hash, Parent, レート) exhibit AI frequencies over 170$\times $ their human baseline. The dominance of English loanwords and katakana technical terms is visually apparent, reflecting LLMs' preference for formal, internationalized vocabulary.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:excess_words}{{1}{6}{Top 30 Japanese excess words ranked by excess score. The horizontal axis shows the excess score (ratio of AI--human frequency difference to human frequency), while bars represent individual words. Words at the top (Hash, Parent, レート) exhibit AI frequencies over 170$\times $ their human baseline. The dominance of English loanwords and katakana technical terms is visually apparent, reflecting LLMs' preference for formal, internationalized vocabulary}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Top 20 excess n-grams (morpheme-level bigrams and trigrams). The highest-scoring n-gram ``Python 例外 処理'' (+224.35) reflects AI models' tendency to produce formulaic multi-word technical expressions. The prevalence of trigrams combining a technology name with an action concept (e.g., ``Docker コンテナ 化'') indicates that AI text over-relies on canonical phrasings rather than the varied expressions found in human writing.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:excess_ngrams}{{2}{7}{Top 20 excess n-grams (morpheme-level bigrams and trigrams). The highest-scoring n-gram ``Python 例外 処理'' (+224.35) reflects AI models' tendency to produce formulaic multi-word technical expressions. The prevalence of trigrams combining a technology name with an action concept (e.g., ``Docker コンテナ 化'') indicates that AI text over-relies on canonical phrasings rather than the varied expressions found in human writing}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Top 15 excess sentence-initial words. AI models disproportionately begin sentences with imperative/instructional words (``try,'' ``Code'') and formal evaluative adjectives (適切, 主要), reflecting a pedagogical, authoritative tone characteristic of instruction-tuned LLMs.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:sentence_starters}{{3}{8}{Top 15 excess sentence-initial words. AI models disproportionately begin sentences with imperative/instructional words (``try,'' ``Code'') and formal evaluative adjectives (適切, 主要), reflecting a pedagogical, authoritative tone characteristic of instruction-tuned LLMs}{figure.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Cross-Model Comparison}{8}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Model-specific excess score heatmap across selected vocabulary items. Rows represent individual LLMs and columns represent excess words. Color intensity encodes the per-model excess score: darker cells indicate higher overuse relative to the human baseline, while white cells indicate absence or near-human-level frequency. Several patterns are notable: (1)\nobreakspace  {}Llama\nobreakspace  {}3.2\nobreakspace  {}1B exhibits extreme scores concentrated in a narrow set of words (Hash: +698.67, Parent: +654.05), reflecting the 1B-parameter model's limited vocabulary distribution and heavy lexical repetition; (2)\nobreakspace  {}Claude generations show a progressive broadening of moderate-to-high excess cells from Haiku to Opus\nobreakspace  {}4, consistent with the generational excess escalation reported in Section\nobreakspace  {}4.3; (3)\nobreakspace  {}GPT-OSS\nobreakspace  {}20B (Swallow) displays a distinctive column pattern in domain-specific terms (e.g., ページング, Broken) absent from other models, likely artifacts of Japanese-specific fine-tuning; (4)\nobreakspace  {}GPT-4o shows comparatively sparse excess, with its strongest signals in specialized vocabulary (原子: +174.05).}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:heatmap}{{4}{9}{Model-specific excess score heatmap across selected vocabulary items. Rows represent individual LLMs and columns represent excess words. Color intensity encodes the per-model excess score: darker cells indicate higher overuse relative to the human baseline, while white cells indicate absence or near-human-level frequency. Several patterns are notable: (1)~Llama~3.2~1B exhibits extreme scores concentrated in a narrow set of words (Hash: +698.67, Parent: +654.05), reflecting the 1B-parameter model's limited vocabulary distribution and heavy lexical repetition; (2)~Claude generations show a progressive broadening of moderate-to-high excess cells from Haiku to Opus~4, consistent with the generational excess escalation reported in Section~4.3; (3)~GPT-OSS~20B (Swallow) displays a distinctive column pattern in domain-specific terms (e.g., ページング, Broken) absent from other models, likely artifacts of Japanese-specific fine-tuning; (4)~GPT-4o shows comparatively sparse excess, with its strongest signals in specialized vocabulary (原子: +174.05)}{figure.4}{}}
\@writefile{toc}{\contentsline {paragraph}{Llama 3.2 1B (open-source, small).}{9}{section*.7}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{GPT-OSS 20B (Swallow).}{9}{section*.8}\protected@file@percent }
